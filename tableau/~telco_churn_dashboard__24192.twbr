      <column caption='Total Customers' datatype='integer' name='[Calculation_332984963805384705]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Actual Churn Rate' datatype='real' name='[Calculation_332984963805863938]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([churn_flag])' />
      </column>
      <column caption='Priority Customers' datatype='integer' name='[Calculation_332984963806220291]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [action_segment] = &quot;Priority: High Value + High Risk&quot; THEN [customer_id] END&#13;&#10;)' />
      </column>
      <column caption='Retained Customers' datatype='integer' name='[Calculation_332984963829555204]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [churn_label] = &quot;No&quot; THEN [customer_id] END&#13;&#10;)' />
      </column>
      <column caption='Retention Rate' datatype='real' name='[Calculation_332984963830611974]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_332984963829555204] / [Calculation_332984963805384705]' />
      </column>
      <column caption='Expected Monthly Revenue at Risk' datatype='real' name='[Calculation_332984963830939655]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue_at_risk])' />
      </column>
      <column caption='Total Revenue KPI' datatype='real' name='[Calculation_332984963831283721]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_revenue])' />
      </column>
      <column caption='Avg. Churn Probability' datatype='real' name='[Calculation_632474339848380416]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([churn_probability])' />
      </column>
      <column caption='KPI_HighRisk_Count' datatype='integer' name='[Calculation_632474339852644354]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [churn_probability] &gt; 0.8 THEN [customer_id] END)' />
      </column>
      <column caption='KPI_HighRisk_Ratio' datatype='real' name='[Calculation_632474339853398019]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_632474339852644354] / COUNTD([customer_id])' />
      </column>
      <column caption='KPI_Avg_Prob' datatype='real' name='[Calculation_632474339857268740]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([churn_probability])' />
      </column>
      <column caption='KPI - Total Revenue' datatype='real' name='[Calculation_632474339858083846]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : MAX([monthly_charge]) }' />
      </column>
      <column caption='Risk Label' datatype='string' name='[Calculation_632474339866144775]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [churn_probability] &gt;= 0.8 THEN &quot;Very High&quot;&#13;&#10;ELSEIF [churn_probability] &gt;= 0.6 THEN &quot;High&quot;&#13;&#10;ELSEIF [churn_probability] &gt;= 0.4 THEN &quot;Medium&quot;&#13;&#10;ELSEIF [churn_probability] &gt;= 0.2 THEN &quot;Low&quot;&#13;&#10;ELSE &quot;Very Low&quot;&#13;&#10;END' />
      </column>
      <column caption='Risk Decile Group' datatype='string' name='[Calculation_632474339873325066]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [churn_probability] &lt;= 0.1 THEN &quot;0-10%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.2 THEN &quot;10-20%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.3 THEN &quot;20-30%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.4 THEN &quot;30-40%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.5 THEN &quot;40-50%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.6 THEN &quot;50-60%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.7 THEN &quot;60-70%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.8 THEN &quot;70-80%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.9 THEN &quot;80-90%&quot;&#13;&#10;ELSE &quot;90-100%&quot;&#13;&#10;END' />
      </column>
      <column caption='Risk Color Filter' datatype='boolean' name='[Calculation_632474339873566731]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[churn_probability] &gt; 0.8' />
      </column>
      <column caption='Service Segment' datatype='string' name='[Calculation_632474339878432781]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[internet_type] + &quot; + &quot; + [contract]' />
      </column>
      <column datatype='string' name='[Churn Reason (group)]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[churn_reason]' new-bin='true'>
          <bin default-name='false' value='&quot;Others&quot;'>
            <value>&quot;Deceased&quot;</value>
            <value>&quot;Don&apos;t know&quot;</value>
            <value>&quot;Extra data charges&quot;</value>
            <value>&quot;Lack of affordable download/upload speed&quot;</value>
            <value>&quot;Lack of self-service on Website&quot;</value>
            <value>&quot;Limited range of services&quot;</value>
            <value>&quot;Long distance charges&quot;</value>
            <value>&quot;Moved&quot;</value>
            <value>&quot;Network reliability&quot;</value>
            <value>&quot;Poor expertise of online support&quot;</value>
            <value>&quot;Poor expertise of phone support&quot;</value>
            <value>&quot;Price too high&quot;</value>
            <value>&quot;Product dissatisfaction&quot;</value>
            <value>&quot;Service dissatisfaction&quot;</value>
          </bin>
        </calculation>
      </column>
