              <calculation class='tableau' formula='AVG(0)' />
            </column>
            <column caption='Contract' datatype='string' name='[contract]' role='dimension' type='nominal' />
            <column-instance column='[customer_id]' derivation='CountD' name='[ctd:customer_id:qk]' pivot='key' type='quantitative' />
            <column aggregation='CountD' caption='Customer Id' datatype='string' default-role='measure' default-type='quantitative' name='[customer_id]' role='dimension' type='nominal' />
            <column caption='Customer Status' datatype='string' name='[customer_status]' role='dimension' type='nominal' />
