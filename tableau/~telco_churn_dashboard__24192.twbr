          </datasources>
          <datasource-dependencies datasource='federated.15cv9ty1696nmi18hc9wt0d1f6dx'>
            <column caption='Total Customers' datatype='integer' name='[Calculation_332984963805384705]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([customer_id])' />
            </column>
            <column caption='AVG(0)' datatype='real' name='[Calculation_332984964287819795]' role='measure' type='quantitative' user:unnamed='Customer Status Distribution'>
              <calculation class='tableau' formula='AVG(0)' />
            </column>
