    <worksheet name='KPI_HighRisk_Ratio'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#0a1d37' fontname='Tableau Semibold' fontsize='12'>High Risk Ratio</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='telco_churn_tableau_dashboard_data' name='federated.15cv9ty1696nmi18hc9wt0d1f6dx' />
          </datasources>
          <datasource-dependencies datasource='federated.15cv9ty1696nmi18hc9wt0d1f6dx'>
            <column caption='KPI_HighRisk_Count' datatype='integer' name='[Calculation_632474339852644354]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF [churn_probability] &gt; 0.8 THEN [customer_id] END)' />
            </column>
            <column caption='KPI_HighRisk_Ratio' datatype='real' name='[Calculation_632474339853398019]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_632474339852644354] / COUNTD([customer_id])' />
            </column>
            <column caption='Churn Probability' datatype='real' name='[churn_probability]' role='measure' type='quantitative' />
            <column caption='Contract' datatype='string' name='[contract]' role='dimension' type='nominal' />
