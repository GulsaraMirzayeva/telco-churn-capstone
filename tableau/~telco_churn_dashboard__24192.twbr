            <column caption='Risk Decile Group' datatype='string' name='[Calculation_632474339873325066]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [churn_probability] &lt;= 0.1 THEN &quot;0-10%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.2 THEN &quot;10-20%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.3 THEN &quot;20-30%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.4 THEN &quot;30-40%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.5 THEN &quot;40-50%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.6 THEN &quot;50-60%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.7 THEN &quot;60-70%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.8 THEN &quot;70-80%&quot;&#13;&#10;ELSEIF [churn_probability] &lt;= 0.9 THEN &quot;80-90%&quot;&#13;&#10;ELSE &quot;90-100%&quot;&#13;&#10;END' />
            </column>
            <column-instance column='[churn_probability]' derivation='Avg' name='[avg:churn_probability:qk]' pivot='key' type='quantitative' />
